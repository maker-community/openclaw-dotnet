@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="appbar-shell">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="app-title">OpenClaw Control</MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">Online</MudChip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" Class="drawer-shell">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-shell">
        <MudContainer MaxWidth="MaxWidth.False" Class="main-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0B6E4F",
            Secondary = "#0A5E8A",
            Tertiary = "#C07F00",
            Background = "#F4F7F5",
            Surface = "#FFFFFF",
            AppbarBackground = "#102A24",
            AppbarText = "#F3FAF6",
            DrawerBackground = "#112821",
            DrawerText = "#D7E8DD",
            TextPrimary = "#12241E",
            TextSecondary = "#46645A"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "14px"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Manrope", "Segoe UI", "sans-serif" }
            },
            H1 = new H1Typography
            {
                FontFamily = new[] { "Space Grotesk", "Manrope", "sans-serif" },
                FontWeight = "700"
            },
            H2 = new H2Typography
            {
                FontFamily = new[] { "Space Grotesk", "Manrope", "sans-serif" },
                FontWeight = "700"
            },
            H3 = new H3Typography
            {
                FontFamily = new[] { "Space Grotesk", "Manrope", "sans-serif" },
                FontWeight = "700"
            },
            H4 = new H4Typography
            {
                FontFamily = new[] { "Space Grotesk", "Manrope", "sans-serif" },
                FontWeight = "700"
            },
            H5 = new H5Typography
            {
                FontFamily = new[] { "Space Grotesk", "Manrope", "sans-serif" },
                FontWeight = "700"
            },
            H6 = new H6Typography
            {
                FontFamily = new[] { "Space Grotesk", "Manrope", "sans-serif" },
                FontWeight = "700"
            }
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
