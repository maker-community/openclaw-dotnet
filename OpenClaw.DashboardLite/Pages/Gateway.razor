@page "/gateway"
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@inject HttpClient Http
@inject OpenClaw.DashboardLite.Services.SettingsService Settings

@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
  <MudStack Spacing="3">
    <MudPaper Class="hero-panel" Elevation="0">
      <MudStack Spacing="2">
        <MudText Typo="Typo.h5">Gateway Console</MudText>
        <MudText Typo="Typo.body2">Proxy API: @DisplayApiBase</MudText>
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
          <MudChip T="string" Color="@(IsConnected ? Color.Success : Color.Error)" Variant="Variant.Filled" Size="Size.Small">
            @(IsConnected ? "已连接" : "未连接")
          </MudChip>
          <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="Connect" Disabled="IsConnected" StartIcon="@Icons.Material.Filled.Link">
            连接
          </MudButton>
          <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Disconnect" Disabled="!IsConnected" StartIcon="@Icons.Material.Filled.LinkOff">
            断开
          </MudButton>
        </MudStack>
      </MudStack>
    </MudPaper>

    <MudTabs Rounded="true" Class="console-tabs">
      <MudTabPanel Text="连接设置" Icon="@Icons.Material.Filled.Tune">
        <MudPaper Class="pa-4 mt-2" Elevation="0">
          <MudStack Spacing="2">
            <MudTextField @bind-Value="_apiBase" Label="Proxy API Base URL" Variant="Variant.Outlined" Placeholder="https://localhost:7242" />
            <MudTextField @bind-Value="_apiKey" Label="X-Api-Key" Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" StartIcon="@Icons.Material.Filled.Save">保存设置</MudButton>
          </MudStack>
        </MudPaper>
      </MudTabPanel>

      <MudTabPanel Text="接口调用" Icon="@Icons.Material.Filled.Api">
        <MudPaper Class="pa-4 mt-2" Elevation="0">
          <MudStack Spacing="2">
            <MudTextField @bind-Value="Method" Label="method" Variant="Variant.Outlined" Placeholder="sessions.list" />
            <MudTextField @bind-Value="ParamsJson" Label="params (JSON)" Variant="Variant.Outlined" Lines="8" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Call" StartIcon="@Icons.Material.Filled.PlayArrow">执行调用</MudButton>

            <MudText Typo="Typo.caption">HTTP Response</MudText>
            <MudPaper Class="code-block" Elevation="0">
              <MudText Typo="Typo.body2">@ResponseJson</MudText>
            </MudPaper>

            <MudText Typo="Typo.caption">Gateway Result Event</MudText>
            <MudPaper Class="code-block" Elevation="0">
              <MudText Typo="Typo.body2">@LastResultJson</MudText>
            </MudPaper>
          </MudStack>
        </MudPaper>
      </MudTabPanel>

      <MudTabPanel Text="事件流" Icon="@Icons.Material.Filled.Timeline">
        <MudPaper Class="pa-4 mt-2" Elevation="0">
          <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.subtitle1">最新 200 条</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="ClearEvents" StartIcon="@Icons.Material.Filled.DeleteSweep">清空</MudButton>
          </MudStack>
          <MudList T="string" Dense="true" Class="events-list">
            @foreach (var e in Events)
            {
              <MudListItem T="string">
                <MudText Typo="Typo.body2">@e</MudText>
              </MudListItem>
            }
          </MudList>
        </MudPaper>
      </MudTabPanel>
    </MudTabs>
  </MudStack>
</MudContainer>

@code {
  private HubConnection? _hub;
  private string _apiBase = "";
  private string? _apiKey;

  private string DisplayApiBase => string.IsNullOrWhiteSpace(_apiBase) ? "(同源)" : _apiBase;

  public bool IsConnected => _hub?.State == HubConnectionState.Connected;

  public string Method { get; set; } = "sessions.list";
  public string ParamsJson { get; set; } = "{}";
  public string ResponseJson { get; set; } = "";
  public string LastResultJson { get; set; } = "";

  public List<string> Events { get; set; } = new();

  protected override async Task OnInitializedAsync()
  {
    var s = await Settings.GetAsync();
    _apiBase = s.ProxyApiBaseUrl;
    _apiKey = s.ApiKey;
  }

  private async Task SaveSettings()
  {
    await Settings.SaveAsync(new OpenClaw.DashboardLite.Services.SettingsService.Settings(_apiBase, _apiKey));
  }

  private void ClearEvents() => Events.Clear();

  private Uri BuildBaseUri()
  {
    if (string.IsNullOrWhiteSpace(_apiBase))
      return new Uri(Nav.BaseUri);

    return new Uri(_apiBase.TrimEnd('/') + "/");
  }

  private async Task Connect()
  {
    if (_hub is not null) return;

    _hub = new HubConnectionBuilder()
      .WithUrl(new Uri(BuildBaseUri(), "hub/openclaw"), opts =>
      {
        if (!string.IsNullOrWhiteSpace(_apiKey))
        {
          opts.Headers.Add("X-Api-Key", _apiKey);
        }
      })
      .WithAutomaticReconnect()
      .Build();

    _hub.On<JsonElement>("gatewayEvent", (evt) =>
    {
      var line = evt.TryGetProperty("event", out var en)
        ? $"{DateTimeOffset.Now:HH:mm:ss} event={en.GetString()}"
        : $"{DateTimeOffset.Now:HH:mm:ss} event";

      Events.Insert(0, line);
      if (Events.Count > 200) Events.RemoveAt(Events.Count - 1);
      InvokeAsync(StateHasChanged);
    });

    // ProxyApi will also push the actual gateway response frame (type=res) via SignalR.
    _hub.On<JsonElement>("gatewayResult", (res) =>
    {
      try
      {
        LastResultJson = JsonSerializer.Serialize(res, new JsonSerializerOptions { WriteIndented = true });
      }
      catch
      {
        LastResultJson = res.ToString();
      }
      InvokeAsync(StateHasChanged);
    });

    await _hub.StartAsync();
  }

  private async Task Disconnect()
  {
    if (_hub is null) return;
    await _hub.StopAsync();
    await _hub.DisposeAsync();
    _hub = null;
  }

  private async Task Call()
  {
    ResponseJson = "";
    LastResultJson = "";

    JsonElement? p = null;
    try
    {
      using var doc = JsonDocument.Parse(string.IsNullOrWhiteSpace(ParamsJson) ? "{}" : ParamsJson);
      p = doc.RootElement.Clone();
    }
    catch (Exception ex)
    {
      ResponseJson = "Invalid JSON: " + ex.Message;
      return;
    }

    var body = new
    {
      method = Method,
      @params = p
    };

    var url = new Uri(BuildBaseUri(), "api/openclaw/call");
    using var req = new HttpRequestMessage(HttpMethod.Post, url)
    {
      Content = JsonContent.Create(body)
    };
    if (!string.IsNullOrWhiteSpace(_apiKey))
      req.Headers.TryAddWithoutValidation("X-Api-Key", _apiKey);

    var resp = await Http.SendAsync(req);
    ResponseJson = await resp.Content.ReadAsStringAsync();
  }

  public async ValueTask DisposeAsync()
  {
    await Disconnect();
  }
}
