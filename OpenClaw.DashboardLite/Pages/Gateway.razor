@page "/gateway"
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@inject HttpClient Http
@inject OpenClaw.DashboardLite.Services.SettingsService Settings

@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
  <MudText Typo="Typo.h4">OpenClaw Dashboard Lite</MudText>
  <MudText Typo="Typo.body2">Proxy API: @_apiBase</MudText>

  <MudPaper Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">Settings</MudText>
    <MudStack Spacing="2" Class="mt-2">
      <MudTextField @bind-Value="_apiBase" Label="ProxyApiBaseUrl" Variant="Variant.Outlined" />
      <MudTextField @bind-Value="_apiKey" Label="X-Api-Key" Variant="Variant.Outlined" />
      <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SaveSettings">Save</MudButton>
    </MudStack>
  </MudPaper>

  <MudPaper Class="pa-4 mt-4">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
      <MudText Typo="Typo.h6">SignalR</MudText>
      <MudChip T="string" Color="@(IsConnected ? Color.Success : Color.Error)" Variant="Variant.Filled">
        @(IsConnected ? "Connected" : "Disconnected")
      </MudChip>
      <MudButton Variant="Variant.Outlined" OnClick="Connect" Disabled="IsConnected">Connect</MudButton>
      <MudButton Variant="Variant.Outlined" OnClick="Disconnect" Disabled="!IsConnected">Disconnect</MudButton>
    </MudStack>

    <MudDivider Class="my-3" />

    <MudStack Spacing="2">
      <MudTextField @bind-Value="@Method" Label="method" Variant="Variant.Outlined" />
      <MudTextField @bind-Value="@ParamsJson" Label="params (JSON)" Lines="6" Variant="Variant.Outlined" />
      <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Call">Call</MudButton>
      <MudText Typo="Typo.caption">Response (from REST)</MudText>
      <MudTextField Value="@ResponseJson" Lines="10" ReadOnly="true" Variant="Variant.Outlined" />

      <MudText Typo="Typo.caption">Result (from gateway res event)</MudText>
      <MudTextField Value="@LastResultJson" Lines="10" ReadOnly="true" Variant="Variant.Outlined" />
    </MudStack>
  </MudPaper>

  <MudPaper Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">Events (latest 200)</MudText>
    <MudList T="string" Dense="true">
      @foreach (var e in Events)
      {
        <MudListItem T="string">
          <MudText Typo="Typo.body2">@e</MudText>
        </MudListItem>
      }
    </MudList>
  </MudPaper>
</MudContainer>

@code {
  private HubConnection? _hub;
  private string _apiBase = "";
  private string? _apiKey;

  public bool IsConnected => _hub?.State == HubConnectionState.Connected;

  public string Method { get; set; } = "sessions.list";
  public string ParamsJson { get; set; } = "{}";
  public string ResponseJson { get; set; } = "";
  public string LastResultJson { get; set; } = "";

  public List<string> Events { get; set; } = new();

  protected override async Task OnInitializedAsync()
  {
    var s = await Settings.GetAsync();
    _apiBase = s.ProxyApiBaseUrl;
    _apiKey = s.ApiKey;
  }

  private async Task SaveSettings()
  {
    await Settings.SaveAsync(new OpenClaw.DashboardLite.Services.SettingsService.Settings(_apiBase, _apiKey));
  }

  private async Task Connect()
  {
    if (_hub is not null) return;

    _hub = new HubConnectionBuilder()
      .WithUrl(new Uri(new Uri(_apiBase.TrimEnd('/') + "/"), "hub/openclaw"), opts =>
      {
        if (!string.IsNullOrWhiteSpace(_apiKey))
        {
          opts.Headers.Add("X-Api-Key", _apiKey);
        }
      })
      .WithAutomaticReconnect()
      .Build();

    _hub.On<JsonElement>("gatewayEvent", (evt) =>
    {
      var line = evt.TryGetProperty("event", out var en)
        ? $"{DateTimeOffset.Now:HH:mm:ss} event={en.GetString()}"
        : $"{DateTimeOffset.Now:HH:mm:ss} event";

      Events.Insert(0, line);
      if (Events.Count > 200) Events.RemoveAt(Events.Count - 1);
      InvokeAsync(StateHasChanged);
    });

    // ProxyApi will also push the actual gateway response frame (type=res) via SignalR.
    _hub.On<JsonElement>("gatewayResult", (res) =>
    {
      try
      {
        LastResultJson = JsonSerializer.Serialize(res, new JsonSerializerOptions { WriteIndented = true });
      }
      catch
      {
        LastResultJson = res.ToString();
      }
      InvokeAsync(StateHasChanged);
    });

    await _hub.StartAsync();
  }

  private async Task Disconnect()
  {
    if (_hub is null) return;
    await _hub.StopAsync();
    await _hub.DisposeAsync();
    _hub = null;
  }

  private async Task Call()
  {
    ResponseJson = "";
    LastResultJson = "";

    JsonElement? p = null;
    try
    {
      using var doc = JsonDocument.Parse(string.IsNullOrWhiteSpace(ParamsJson) ? "{}" : ParamsJson);
      p = doc.RootElement.Clone();
    }
    catch (Exception ex)
    {
      ResponseJson = "Invalid JSON: " + ex.Message;
      return;
    }

    var body = new
    {
      method = Method,
      @params = p
    };

    var url = new Uri(new Uri(_apiBase.TrimEnd('/') + "/"), "api/openclaw/call");
    using var req = new HttpRequestMessage(HttpMethod.Post, url)
    {
      Content = JsonContent.Create(body)
    };
    if (!string.IsNullOrWhiteSpace(_apiKey))
      req.Headers.TryAddWithoutValidation("X-Api-Key", _apiKey);

    var resp = await Http.SendAsync(req);
    ResponseJson = await resp.Content.ReadAsStringAsync();
  }

  public async ValueTask DisposeAsync()
  {
    await Disconnect();
  }
}
