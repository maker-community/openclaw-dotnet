@page "/not-found"
@layout MainLayout

<MudPaper Class="pa-6 mt-6" Elevation="0">
	<MudStack Spacing="2">
		<MudText Typo="Typo.h5">页面不存在</MudText>
		<MudText Typo="Typo.body1">你访问的地址无效，请返回首页或打开 Gateway Console。</MudText>
		<MudStack Row="true" Spacing="2">
			<MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">返回首页</MudButton>
			<MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/gateway">打开控制台</MudButton>
		</MudStack>
	</MudStack>
</MudPaper>